---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About · ${SITE_TITLE}`} description="About me" />
  </head>
  <body>
    <Header />

    <main>
      <h1 class="page-title">About Huoi</h1>

      <div class="prose about-prose">
        <p>
          I'm a student and a computer science, music, sports and cubing
          hobbyist.
        </p>

        <p>I write about whatever I want.</p>

        <h2>Currently</h2>
        <ul>
          <li>Working on — A Levels (😔)</li>
          <li>Reading — <em>1984</em> by George Orwell</li>
          <li>Based in — Singapore</li>
        </ul>

        <h2>Elsewhere</h2>
        <ul>
          <li>
            <a
              href="https://www.youtube.com/@huoiouh"
              target="_blank"
              rel="noopener noreferrer">Youtube</a>
          </li>
          <li>
            <a
              href="https://github.com/huoi"
              target="_blank"
              rel="noopener noreferrer">GitHub</a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/le-huy-truong-4028352b2"
              target="_blank"
              rel="noopener noreferrer">LinkedIn</a>
          </li>
        </ul>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-title {
    font-size: 32px;
    font-weight: bold;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    border-bottom: 2px inset var(--color-border-3d);
  }

  .about-prose {
    max-width: var(--width-prose);
  }

  .about-prose h2 {
    font-size: 24px;
    font-weight: bold;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .about-prose ul {
    list-style: square outside;
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .about-prose li {
    font-size: 16px;
    margin-bottom: 5px;
  }
</style>
