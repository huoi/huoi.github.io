---
import { SITE_TITLE } from "../consts";
---

<header>
  <nav>
    <a href="/" class="site-name">{SITE_TITLE}</a>
    <div class="nav-links">
      <a href="/writing">writing</a>
      <a href="/about">about</a>
    </div>
  </nav>
</header>

<style>
  header {
    width: 100%;
    /* Classic desktop UI gray background with a 3D pop */
    background-color: var(--color-ui);
    padding: 10px 15px;
    border-bottom: 3px outset var(--color-surface);
    border-top: 2px solid var(--color-surface);
  }

  nav {
    max-width: var(--width-wide);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-name {
    font-size: 24px;
    font-weight: bold;
    color: var(--color-text);
    text-decoration: none;
    /* No transitions, no opacity changes */
  }

  .site-name:hover {
    text-decoration: underline; /* Just a raw, instant underline */
  }

  .nav-links {
    display: flex;
    gap: 20px; /* Keeping gap so you don't have to rewrite your HTML */
    align-items: center;
  }

  .nav-links a {
    font-size: 16px;
    color: var(--color-link); /* Pure browser blue */
    text-decoration: underline;
    padding: 2px 4px;
  }

  /* Must include the holy trinity of early web pseudo-classes */
  .nav-links a:visited {
    color: var(--color-visited);
  }

  .nav-links a:active {
    color: var(--color-active);
  }

  .nav-links a:hover {
    /* A classic 90s trick: invert the colors on hover for a "highlight" effect */
    background-color: var(--color-link);
    color: var(--color-surface);
    text-decoration: none;
  }

  /* Highlight current page - make it look like a depressed button or static text */
  .nav-links a[aria-current="page"] {
    color: var(--color-text);
    font-weight: bold;
    text-decoration: none;
    background-color: transparent;
    cursor: default;
  }

  @media (max-width: 480px) {
    .nav-links {
      gap: 10px;
    }

    .site-name {
      font-size: 18px;
    }
  }
</style>
