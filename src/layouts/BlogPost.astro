---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

const { title, description, pubDate, updatedDate } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />

    <main class="post-main">
      <article>
        <!-- Post header -->
        <header class="post-header">
          <div class="post-meta">
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <span class="post-updated">
                  · updated <FormattedDate date={updatedDate} />
                </span>
              )
            }
          </div>
          <h1 class="post-title">{title}</h1>
          {description && <p class="post-description">{description}</p>}
        </header>

        <hr class="post-divider" />

        <!-- Post body -->
        <div class="prose">
          <slot />
        </div>

        <!-- Back link -->
        <div class="post-footer">
          <a href="/writing" class="back-link">← all posts</a>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* Header */
  .post-header {
    margin-bottom: var(--space-md);
    border-bottom: 2px inset var(--color-border-3d);
    padding-bottom: var(--space-sm);
  }

  .post-meta {
    font-size: 14px;
    font-family: var(--font-mono);
    color: var(--color-text);
    margin-bottom: 5px;
  }

  .post-updated {
    font-style: italic;
  }

  .post-title {
    font-size: 32px;
    font-weight: bold;
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .post-description {
    font-size: 16px;
    font-style: italic;
    margin-bottom: 0;
    max-width: var(--width-prose);
  }

  .post-divider {
    display: none; /* using header border instead */
  }

  /* Prose overrides */
  .prose {
    font-size: 16px;
    line-height: 1.4;
  }

  .prose h2 {
    font-size: 24px;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .prose h3 {
    font-size: 18px;
    margin-top: var(--space-md);
    margin-bottom: 5px;
  }

  .prose p {
    margin-bottom: 15px;
  }

  .prose a {
    color: var(--color-link);
    text-decoration: underline;
  }

  .prose a:visited {
    color: var(--color-visited);
  }

  .prose a:hover {
    background-color: var(--color-link);
    color: var(--color-surface);
    text-decoration: none;
  }

  .prose ul,
  .prose ol {
    padding-left: var(--space-lg);
    margin-bottom: 15px;
  }

  .prose li {
    margin-bottom: 5px;
  }

  .prose blockquote {
    border-left: none;
    padding: 10px 20px;
    margin: 20px 40px;
    font-style: italic;
    background-color: var(--color-ui);
    border: 1px solid var(--color-border-3d);
  }

  .prose img {
    border: 2px solid var(--color-text);
    margin: var(--space-md) 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
    border: 1px solid var(--color-text);
  }

  .prose th {
    background-color: var(--color-ui);
    font-weight: bold;
    text-align: center;
    border: 1px solid var(--color-text);
    padding: 5px;
    text-transform: none;
    letter-spacing: normal;
  }

  .prose td {
    border: 1px solid var(--color-text);
    padding: 5px;
    vertical-align: top;
  }

  /* Back link */
  .post-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 2px inset var(--color-border-3d);
  }

  .back-link {
    font-size: 16px;
    color: var(--color-link);
    text-decoration: underline;
  }

  .back-link:hover {
    background-color: var(--color-link);
    color: var(--color-surface);
    text-decoration: none;
  }
</style>
